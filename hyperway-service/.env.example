# ── Chain connection ─────────────────────────────────────────────────────────
RPC_URL=https://westend-asset-hub-eth-rpc.polkadot.io
CONTRACT_ADDRESS=0xYourDeployedContractAddress

# ── Provider wallet (keep secret — never commit the real key) ────────────────
PROVIDER_PRIVATE_KEY=0xYourPrivateKey

# ── Pinata IPFS ──────────────────────────────────────────────────────────────
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_KEY=your_pinata_secret_api_key

# ── Supabase (optional — enables live dashboard status reporting) ─────────────
# Set these to enable the DaemonStatusPanel in the provider dashboard.
# Use the service-role key here (the daemon runs on a trusted server).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ── Optional tuning ──────────────────────────────────────────────────────────
# How often the daemon polls the chain for new events (seconds, default 15)
POLL_INTERVAL=15

# Python logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
